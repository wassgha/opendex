{
  "name": "opendex",
  "version": "0.1.0",
  "description": "OpenDex — a voice-first agentic harness for the desktop.",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "smoke:chat": "tsx scripts/smoke-chat.ts",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.49.1",
    "@huggingface/transformers": "^4.2.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@picovoice/porcupine-web": "^4.0.0",
    "@picovoice/web-voice-processor": "^4.0.10",
    "ai": "^6.0.193",
    "dotenv": "^17.4.2",
    "vosk-browser": "^0.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "io.opendex.app",
    "productName": "OpenDex",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}

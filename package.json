{
  "name": "opendex",
  "version": "1.1.7",
  "description": "OpenDex — a voice-first agentic harness for the desktop.",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "author": {
    "name": "wassgha",
    "email": "wassgha@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wassgha/opendex.git"
  },
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "smoke:chat": "tsx scripts/smoke-chat.ts",
    "smoke:realtime": "tsx scripts/smoke-realtime.ts",
    "dist": "electron-vite build && electron-builder",
    "release": "electron-vite build && electron-builder --publish always",
    "cut:patch": "pnpm version patch -m \"Release v%s\" && git push --follow-tags",
    "cut:minor": "pnpm version minor -m \"Release v%s\" && git push --follow-tags",
    "cut:major": "pnpm version major -m \"Release v%s\" && git push --follow-tags"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.86",
    "@ai-sdk/gateway": "4.0.0-canary.107",
    "@ai-sdk/openai": "^3.0.74",
    "@elevenlabs/elevenlabs-js": "^2.49.1",
    "@huggingface/transformers": "^4.2.0",
    "@meridius-labs/apple-on-device-ai": "^1.6.2",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@picovoice/web-voice-processor": "^4.0.10",
    "ai": "^6.0.193",
    "dotenv": "^17.4.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "vosk-browser": "^0.0.8",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^1.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vite": "^7.3.5"
  },
  "build": {
    "appId": "io.opendex.app",
    "productName": "OpenDex",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wassgha",
        "repo": "opendex"
      }
    ],
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@nut-tree-fork/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "artifactName": "${productName}-mac-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "OpenDex listens to your voice to run agentic commands.",
        "NSCameraUsageDescription": "OpenDex may capture the screen to see and control your desktop."
      }
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-Setup.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "${productName}-linux.${ext}"
    }
  }
}

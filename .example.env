# Required — ElevenLabs API key for TTS
ELEVENLABS_API_KEY=

# Optional — voice ID. Defaults to George (deep British male) if unset.
# Browse: https://elevenlabs.io/app/voice-library
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb

# Optional — model. Defaults to eleven_turbo_v2_5 for low latency.
# ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Required — Vercel AI Gateway API key (or rely on OIDC when deployed to Vercel)
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=

# Optional — override the underlying model. Defaults to anthropic/claude-sonnet-4-6.
# JARVIS_MODEL=anthropic/claude-sonnet-4-6

# Optional — Tavily API key for the webSearch tool. Without it, web search is disabled.
# https://tavily.com
TAVILY_API_KEY=
